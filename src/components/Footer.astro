<style>
	footer {
		padding: 3rem 1rem;
		background: var(--surface);
		color: rgb(var(--black));
		text-align: center;
		border-top: 2px solid rgb(var(--black));
		font-family: var(--font-mono);
	}
	p {
		margin: 0.35rem 0;
		font-size: 0.85rem;
		text-transform: uppercase;
		font-weight: 700;
	}
	.social-links {
		display: flex;
		justify-content: center;
		gap: 1rem;
