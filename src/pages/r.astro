---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import RouteMotion from '../components/RouteMotion.astro';
import { SITE_TITLE } from '../consts';

const PDF_URL = '/Resumes_Usama_12yrs.pdf';
const EMBED_PDF_URL = `${PDF_URL}#zoom=90&navpanes=0`;
const EMBED_PDF_URL_MOBILE = `${PDF_URL}#view=FitH&zoom=page-width&navpanes=0`;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Resume | ${SITE_TITLE}`} description="Resume of Usama Ansari in PDF format." />
	</head>
	<body>
		<Header />
		<main class="resume-page">
			<section class="intro" data-route-reveal style="--stagger: 0;">
				<h1>Resume</h1>
				<p>
					View the latest PDF resume below or download a copy.
				</p>
				<div class="download-actions">
					<a class="download-btn" href={PDF_URL} download data-resume-download>Download PDF</a>
					<span class="download-feedback" data-download-feedback aria-live="polite" role="status"></span>
				</div>
			</section>

			<section class="viewer" aria-label="Resume PDF preview" data-route-reveal style="--stagger: 1;">
				<div class="desktop-viewer">
					<object data={EMBED_PDF_URL} type="application/pdf" class="pdf-frame pdf-frame-desktop">
						<p>
							Your browser does not support inline PDF preview.
							<a href={PDF_URL} target="_blank" rel="noreferrer">Open resume PDF in a new tab</a>.
						</p>
					</object>
				</div>
				<div class="mobile-viewer">
					<object data={EMBED_PDF_URL_MOBILE} type="application/pdf" class="pdf-frame pdf-frame-mobile">
						<p>
							Your browser does not support inline PDF preview.
							<a href={PDF_URL} target="_blank" rel="noreferrer">Open resume PDF in a new tab</a>.
						</p>
					</object>
				</div>
			</section>
		</main>
		<script is:inline>
			const downloadButton = document.querySelector('[data-resume-download]');
			const downloadFeedback = document.querySelector('[data-download-feedback]');
			const notices = ['Download started.', 'Resume on the way.'];

			downloadButton?.addEventListener('click', () => {
				if (!downloadFeedback) return;
				downloadFeedback.textContent = notices[Math.floor(Math.random() * notices.length)];
				downloadFeedback.dataset.state = 'active';
				window.setTimeout(() => {
					downloadFeedback.textContent = '';
					delete downloadFeedback.dataset.state;
				}, 1800);
			});
		</script>
		<RouteMotion />
		<Footer />
	</body>
</html>

<style>
	.resume-page {
		display: grid;
		gap: 1.5rem;
	}

	.intro p {
		margin-bottom: 1rem;
		max-width: 70ch;
	}

	.download-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.65rem 1rem;
		border: 1px solid var(--accent-dark);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.03em;
		font-size: 0.85rem;
		text-decoration: none;
		min-height: 2.75rem;
		color: oklch(0.23 0.04 34);
		background: color-mix(in oklch, var(--accent) 92%, white);
		transition:
			transform 220ms var(--ease-out-quart),
			background-color 220ms var(--ease-out-quart),
			color 220ms var(--ease-out-quart),
			box-shadow 220ms var(--ease-out-quart);
		will-change: transform;
	}
	.download-actions {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}
	.download-feedback {
		font-family: var(--font-mono);
		font-size: 0.78rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		min-height: 1.2em;
	}
	.download-feedback[data-state='active'] {
		color: var(--success);
	}

	.download-btn:hover {
		background: color-mix(in oklch, var(--accent) 84%, white);
		color: oklch(0.19 0.04 34);
		transform: translateY(-2px) scale(1.02);
		box-shadow: 3px 3px 0 color-mix(in oklch, var(--accent-dark) 60%, rgb(var(--black)));
	}

	.viewer {
		border: 1px solid color-mix(in oklch, var(--ink-blue) 25%, rgb(var(--gray-light)));
		background: color-mix(in oklch, var(--ink-blue-soft) 58%, var(--surface));
		padding: 0.5rem;
		transition:
			transform 260ms var(--ease-out-quart),
			box-shadow 260ms var(--ease-out-quart);
		will-change: transform;
	}
	.viewer:hover {
		transform: translateY(-2px);
		box-shadow: 4px 4px 0 color-mix(in oklch, var(--ink-blue) 58%, rgb(var(--black)));
	}

	.pdf-frame {
		display: block;
		width: 100%;
		height: 78vh;
		min-height: 640px;
	}

	.desktop-viewer {
		display: block;
	}

	.mobile-viewer {
		display: none;
	}

	.pdf-frame-mobile {
		display: none;
	}

	@media (max-width: 720px) {
		.download-actions {
			flex-direction: column;
			align-items: flex-start;
			gap: 0.5rem;
		}
		.desktop-viewer {
			display: none !important;
		}

		.mobile-viewer {
			display: block !important;
		}

		.pdf-frame-desktop {
			display: none !important;
		}

		.pdf-frame-mobile {
			display: block !important;
		}

		.pdf-frame {
			height: 75vh;
			min-height: 520px;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.download-btn,
		.viewer {
			transition: none;
			will-change: auto;
		}
		.download-btn:hover,
		.viewer:hover {
			transform: none;
			box-shadow: none;
		}
	}
</style>
