---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import RouteMotion from '../components/RouteMotion.astro';
import { SITE_TITLE } from '../consts';

const sections = [
	{
		id: 'hardware',
		num: '01',
		title: 'Hardware',
		items: [
			{ label: 'Mac Mini M4', badge: 'DAILY DRIVER' },
			{ label: 'External monitor — coding + docs side-by-side', badge: null },
		{ label: 'AirPods Pro 2', badge: 'ESSENTIAL' },
		],
	},
	{
		id: 'editor',
		num: '02',
		title: 'Editor & Terminal',
		items: [
			{ label: 'Visual Studio Code', badge: 'DAILY DRIVER' },
			{ label: 'GitHub Copilot — AI-assisted coding workflow', badge: 'PREFERRED' },
			{ label: 'Ghostty — terminal emulator', badge: 'DAILY DRIVER' },
		{ label: 'OpenCode — terminal AI coding assistant', badge: 'OCCASIONAL' },
			{ label: 'Git + GitHub CLI for PR and release workflows', badge: null },
		{ label: 'GitHub Copilot CLI — AI in the terminal', badge: 'PREFERRED' },
		],
	},
	{
		id: 'stack',
		num: '03',
		title: 'Engineering Stack',
		items: [
			{ label: 'TypeScript & Node.js — web and tooling', badge: 'PREFERRED' },
			{ label: '.NET / C# — backend and platform engineering', badge: null },
			{ label: 'Docker — local parity and service orchestration', badge: 'ESSENTIAL' },
			{ label: 'Azure — cloud-native architecture and deployment', badge: null },
		],
	},
	{
		id: 'apps',
		num: '04',
		title: 'Daily Apps',
		items: [
			{ label: 'Raycast — launcher, snippets, and productivity shortcuts', badge: 'FAVOURITE' },
			{ label: 'Google Chrome', badge: 'DAILY DRIVER' },
			{ label: 'ChatGPT — AI assistant for research and drafting', badge: 'DAILY DRIVER' },
			{ label: 'WhatsApp', badge: null },
		],
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Uses | ${SITE_TITLE}`} description="Software, apps, and Mac setup used by Usama Ansari." />
	</head>
	<body>
		<Header />
		<main class="uses-page">

			<div class="manifest-header" data-route-reveal style="--stagger: 0;">
				<div class="manifest-meta">
					<span class="manifest-label">SYSTEM_MANIFEST.txt</span>
					<span class="manifest-label">REV&nbsp;2026.03</span>
					<span class="manifest-label">AUTHOR: USAMA ANSARI</span>
				</div>
				<h1>Uses</h1>
				<p class="tagline">
					A living inventory of the software, hardware, and principles that power my engineering work, writing,
					and daily focus. Updated when something changes.
				</p>
			</div>

			<div class="manifest-body">

				<nav class="manifest-toc" aria-label="Page sections" data-route-reveal style="--stagger: 1;">
					<p class="toc-heading">// Contents</p>
					{sections.map((s) => (
						<a href={`#${s.id}`} class="toc-link">
							<span class="toc-num">{s.num}</span>
							<span>{s.title}</span>
						</a>
					))}
				</nav>

				<div class="manifest-sections">
					{sections.map((s, index) => (
						<section class="manifest-section" id={s.id} data-route-reveal style={`--stagger: ${index + 2};`}>
							<div class="section-label">
								<span class="section-num">{s.num}</span>
								<h2 class="section-title">{s.title}</h2>
							</div>
							<ul class="item-list">
								{s.items.map((item) => (
									<li class="item">
										<span class="item-arrow">→</span>
										<span class="item-label">{item.label}</span>
										{item.badge && (
											<span class:list={['badge', `badge--${item.badge.toLowerCase().replace(/\s/g, '-')}`]}>
												{item.badge}
											</span>
										)}
									</li>
								))}
							</ul>
						</section>
					))}
				</div>

			</div>
		</main>
		<RouteMotion />
		<Footer />
	</body>
</html>

<style>
	.uses-page {
		width: 100%;
		box-sizing: border-box;
		max-width: 960px;
		padding-bottom: 5rem;
		overflow-x: hidden;
	}

	/* ── Manifest Header ── */
	.manifest-header {
		border-bottom: 2px solid color-mix(in oklch, var(--accent) 45%, var(--ink-blue));
		padding-bottom: 2rem;
		margin-bottom: 3rem;
	}
	.manifest-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 1.5rem;
		margin-bottom: 1.5rem;
	}
	.manifest-label {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: oklch(0.2 0.03 258);
		background: color-mix(in oklch, var(--accent-soft) 72%, white);
		padding: 0.2rem 0.5rem;
	}
	.manifest-label:nth-child(2) {
		background: color-mix(in oklch, var(--ink-blue-soft) 75%, white);
		color: var(--ink-blue);
	}
	.manifest-label:nth-child(3) {
		background: color-mix(in oklch, var(--accent) 88%, white);
		color: oklch(0.22 0.03 258);
	}
	.manifest-header h1 {
		font-size: clamp(4rem, 10vw, 7rem);
		margin-bottom: 0.5rem;
		line-height: 0.9;
	}
	.tagline {
		max-width: 60ch;
		font-family: var(--font-body);
		font-size: 1rem;
		line-height: 1.7;
		color: color-mix(in oklch, var(--ink-blue) 55%, rgb(var(--gray-dark)));
		margin: 0;
	}

	/* ── Body Layout ── */
	.manifest-body {
		display: grid;
		grid-template-columns: 180px 1fr;
		gap: 3rem;
		align-items: start;
		min-width: 0;
	}

	/* ── TOC Sidebar ── */
	.manifest-toc {
		position: sticky;
		top: 5rem;
		display: flex;
		flex-direction: column;
		gap: 0.1rem;
		border: 1.5px solid color-mix(in oklch, var(--ink-blue) 42%, rgb(var(--black)));
		background: color-mix(in oklch, var(--ink-blue-soft) 60%, var(--surface));
		padding: 1rem;
		transition:
			transform 260ms var(--ease-out-quart),
			box-shadow 260ms var(--ease-out-quart);
		will-change: transform;
	}
	.manifest-toc:hover {
		transform: translateY(-2px);
		box-shadow: 4px 4px 0 color-mix(in oklch, var(--ink-blue) 54%, rgb(var(--black)));
	}
	.toc-heading {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		margin: 0 0 0.75rem;
		border-bottom: 1.5px solid color-mix(in oklch, var(--ink-blue) 35%, rgb(var(--black)));
		padding-bottom: 0.5rem;
	}
	.toc-link {
		display: flex;
		align-items: baseline;
		gap: 0.5rem;
		padding: 0.3rem 0;
		min-height: 2.5rem;
		font-family: var(--font-mono);
		font-size: 0.78rem;
		text-decoration: none;
		color: rgb(var(--black));
		text-transform: uppercase;
		font-weight: 700;
		border-bottom: 1px solid transparent;
		transition:
			color 200ms var(--ease-out-quart),
			transform 200ms var(--ease-out-quart);
	}
	.toc-link:hover {
		background: transparent;
		color: var(--accent);
		transform: translateX(2px);
	}
	.toc-num {
		color: var(--accent);
		flex-shrink: 0;
	}

	/* ── Sections ── */
	.manifest-sections {
		display: flex;
		flex-direction: column;
		gap: 0;
		min-width: 0;
		overflow: hidden;
	}
	.manifest-section {
		border-bottom: 1.5px solid color-mix(in oklch, var(--ink-blue) 34%, rgb(var(--black)));
		padding: 2.5rem 0;
	}
	.manifest-section:first-child {
		padding-top: 0;
	}
	.section-label {
		display: flex;
		align-items: baseline;
		gap: 1rem;
		margin-bottom: 1.5rem;
	}
	.section-num {
		font-family: var(--font-mono);
		font-size: 0.8rem;
		font-weight: 700;
		color: var(--accent);
		flex-shrink: 0;
	}
	.section-title {
		font-family: var(--font-serif);
		font-size: clamp(2rem, 4vw, 2.8rem);
		font-weight: 400;
		letter-spacing: -0.02em;
		margin: 0;
		line-height: 1.08;
	}

	/* ── Items ── */
	.item-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0;
	}
	.item {
		display: flex;
		align-items: baseline;
		gap: 0.75rem;
		padding: 0.65rem 0;
		border-top: 1px solid rgb(var(--gray-light));
		font-family: var(--font-body);
		font-size: 0.98rem;
		line-height: 1.62;
		transition:
			transform 200ms var(--ease-out-quart),
			background-color 200ms var(--ease-out-quart);
		will-change: transform;
	}
	.item:hover {
		transform: translateX(3px);
		background: color-mix(in oklch, var(--accent-soft) 50%, white);
	}
	.item-arrow {
		color: rgb(var(--gray));
		flex-shrink: 0;
		font-size: 0.75rem;
	}
	.item-label {
		flex: 1;
		min-width: 0;
		word-break: break-word;
		overflow-wrap: anywhere;
	}
	.badge {
		font-family: var(--font-mono);
		font-size: 0.63rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		padding: 0.15rem 0.4rem;
		white-space: nowrap;
		flex-shrink: 0;
		border: 1.5px solid color-mix(in oklch, var(--ink-blue) 50%, rgb(var(--black)));
		color: color-mix(in oklch, var(--ink-blue) 70%, rgb(var(--black)));
	}
	.badge--daily-driver {
		background: color-mix(in oklch, var(--ink-blue) 88%, white);
		border-color: var(--ink-blue);
		color: oklch(0.24 0.03 248);
	}
	.badge--favourite {
		background: var(--accent);
		color: oklch(0.22 0.03 258);
		border-color: var(--accent);
	}
	.badge--essential {
		background: color-mix(in oklch, var(--success) 90%, white);
		color: oklch(0.26 0.05 156);
		border-color: var(--success);
	}
	.badge--preferred {
		border-color: color-mix(in oklch, var(--accent-dark) 55%, rgb(var(--black)));
		color: color-mix(in oklch, var(--accent-dark) 70%, rgb(var(--black)));
	}
	.badge--rule {
		background: var(--accent);
		color: var(--surface);
		border-color: var(--accent);
	}
	.badge--occasional {
		border-color: rgb(var(--gray));
		color: rgb(var(--gray));
	}

	/* ── Responsive ── */
	@media (max-width: 720px) {
		html, body {
			overflow-x: hidden;
			max-width: 100%;
		}
		.manifest-header {
			margin-bottom: 2rem;
			padding-bottom: 1.5rem;
		}
		.uses-page {
			padding-left: 0.6rem;
			padding-right: 0.6rem;
		}
		.manifest-meta {
			gap: 0.5rem;
			margin-bottom: 1rem;
		}
		.manifest-label {
			font-size: 0.65rem;
			padding: 0.15rem 0.4rem;
		}
		.manifest-header h1 {
			font-size: clamp(2.5rem, 12vw, 4rem);
			word-break: break-word;
		}
		.tagline {
			font-size: 0.8rem;
		}

		.manifest-body {
			grid-template-columns: 1fr;
			gap: 1.5rem;
			width: 100%;
			max-width: 100%;
		}

		/* Collapse TOC to a horizontal scroll strip */
		.manifest-toc {
			position: static;
			flex-direction: row;
			flex-wrap: nowrap;
			overflow-x: auto;
			overflow-y: hidden;
			-webkit-overflow-scrolling: touch;
			max-width: 100%;
			width: 100%;
			min-width: 0;
			box-sizing: border-box;
			gap: 0;
			padding: 0.75rem;
		}
		.toc-heading {
			display: none;
		}
		.toc-link {
			flex-shrink: 0;
			padding: 0.3rem 0.75rem;
			border-bottom: none;
			border-right: 1px solid rgb(var(--black));
			font-size: 0.72rem;
		}
		.toc-link:last-child {
			border-right: none;
		}

		.manifest-section {
			padding: 1.75rem 0;
		}
		.section-title {
			font-size: clamp(1.6rem, 6vw, 2rem);
		}
		.section-label {
			margin-bottom: 1rem;
		}

		/* Stack badge below label on very narrow screens */
		.item {
			flex-wrap: wrap;
			gap: 0.4rem 0.75rem;
			font-size: 0.82rem;
		}
		.badge {
			font-size: 0.6rem;
			padding: 0.1rem 0.3rem;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.manifest-toc,
		.toc-link,
		.item {
			transition: none;
			will-change: auto;
		}
		.manifest-toc:hover,
		.toc-link:hover,
		.item:hover {
			transform: none;
			box-shadow: none;
			background: transparent;
		}
	}
</style>
