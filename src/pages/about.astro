---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import RouteMotion from '../components/RouteMotion.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`About | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="about-page">
			<section class="intro" data-route-reveal style="--stagger: 0;">
				<h1>About</h1>
				<p>
					I am Usama Ansari, a Senior Software Engineer with 12.3+ years of experience designing and
					delivering distributed systems on Microsoft Azure.
				</p>
				<p>
					I focus on AI platform engineering, high-availability APIs, real-time telemetry, and secure
					cloud-native architecture. This timeline highlights the major milestones in my career.
				</p>
			</section>

			<section data-route-reveal style="--stagger: 1;">
				<h2>Career Timeline</h2>
				<ol class="timeline">
					<li class="timeline-item" data-route-reveal style="--stagger: 2;">
						<div class="period">May 2016 - Present</div>
						<div class="card">
							<h3>Microsoft - Software Engineer 2</h3>
							<p class="meta">Hyderabad, India</p>
							<ul>
								<li>
									Architected the Azure Networking AI Agent Platform with MCP support, memory
									management, multi-model orchestration (GPT-5.2 and GPT-mini), evaluation pipelines,
									and enterprise security controls.
								</li>
								<li>
									Designed the platform on Azure AI Foundry, Azure Container Apps, and Cosmos DB
									(operational and vector storage), and led decisions on observability, persistence, and
									secure integration.
								</li>
								<li>
									Enabled early adoption with 10+ production agents, 52 active users, 16K-20K API
									requests per month, and approximately 712 million tokens processed monthly.
								</li>
								<li>
									Designed and scaled a multi-region Device Health API platform processing
									approximately 150 million requests per day with 99.99%-99.999% reliability, supporting
									health monitoring across more than 3 million Azure nodes.
								</li>
								<li>
									Implemented schema-driven dynamic tooling for Net Assist workflows, reducing
									per-workflow development effort by up to one week and improving team onboarding.
								</li>
								<li>
									Served as S360 SPOC, owning security and compliance for AI Agent Platform and Device
									Health services, including secure configuration, vulnerability remediation, and
									proactive reviews.
								</li>
								<li>
									Acted as the primary architecture SME, driving design reviews and mentoring engineers
									on scalable, secure, resilient cloud-native systems.
								</li>
							</ul>
						</div>
					</li>

					<li class="timeline-item" data-route-reveal style="--stagger: 3;">
						<div class="period">Nov 2013 - Apr 2016</div>
						<div class="card">
							<h3>Capgemini - Software Engineer</h3>
							<p class="meta">Mumbai, India</p>
							<ul>
								<li>
									Built enterprise web applications for Abbott and SCA using .NET, SQL Server, and
									Azure.
								</li>
								<li>
									Contributed across requirements analysis, development, testing, and production
									support.
								</li>
							</ul>
						</div>
					</li>

					<li class="timeline-item" data-route-reveal style="--stagger: 4;">
						<div class="period">Jul 2013</div>
						<div class="card">
							<h3>Bachelor of Science in Information Technology</h3>
							<p class="meta">Mumbai University</p>
						</div>
					</li>
				</ol>
			</section>
		</main>
		<RouteMotion />
		<Footer />
	</body>
</html>
<style>
	.about-page {
		display: grid;
		gap: 2.5rem;
	}
	.intro p {
		max-width: 72ch;
	}
	.timeline {
		list-style: none;
		margin: 0;
		padding: 0 0 0 1rem;
		border-left: 1px solid color-mix(in oklch, var(--ink-blue) 28%, rgb(var(--gray-light)));
		display: grid;
		gap: 1.75rem;
	}
	.timeline-item {
		position: relative;
		padding-left: 1rem;
	}
	.timeline-item::before {
		content: '';
		position: absolute;
		left: -1.4rem;
		top: 0.35rem;
		width: 0.65rem;
		height: 0.65rem;
		border-radius: 50%;
		background: var(--accent);
	}
	.timeline-item:nth-child(2)::before {
		background: var(--ink-blue);
	}
	.timeline-item:nth-child(3)::before {
		background: var(--success);
	}
	.period {
		font-size: 0.9rem;
		color: color-mix(in oklch, var(--ink-blue) 75%, rgb(var(--gray)));
		margin-bottom: 0.45rem;
		text-transform: uppercase;
		letter-spacing: 0.04em;
	}
	.card {
		background: color-mix(in oklch, var(--ink-blue-soft) 60%, var(--surface));
		border: 1px solid color-mix(in oklch, var(--ink-blue) 28%, rgb(var(--gray-light)));
		border-radius: 8px;
		padding: 1rem 1rem 0.75rem;
		transition:
			transform 260ms var(--ease-out-quart),
			box-shadow 260ms var(--ease-out-quart),
			border-color 260ms var(--ease-out-quart);
		will-change: transform;
	}
	.timeline-item:nth-child(odd) .card {
		background: color-mix(in oklch, var(--accent-soft) 58%, var(--surface));
	}
	.timeline-item:hover .card {
		transform: translateY(-3px);
		box-shadow: 4px 4px 0 color-mix(in oklch, var(--accent-dark) 55%, rgb(var(--black)));
		border-color: color-mix(in oklch, var(--accent) 45%, rgb(var(--black)));
	}
	.card h3 {
		margin-bottom: 0.25rem;
		font-size: 1.3rem;
		color: color-mix(in oklch, var(--accent-dark) 70%, rgb(var(--black)));
	}
	.meta {
		margin-bottom: 0.75rem;
		color: color-mix(in oklch, var(--ink-blue) 60%, rgb(var(--gray)));
		font-size: 0.95rem;
	}
	.card ul {
		margin: 0;
		padding-left: 1.1rem;
	}

	@media (prefers-reduced-motion: reduce) {
		.card {
			transition: none;
			will-change: auto;
		}
		.timeline-item:hover .card {
			transform: none;
			box-shadow: none;
		}
	}
</style>
