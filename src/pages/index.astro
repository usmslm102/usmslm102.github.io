---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const latestPosts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 4);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="home">
			<section class="hero">
				<h1 data-reveal="hero" style="--hero-order: 0;">Hi, I’m Usama.</h1>
				<p data-reveal="hero" style="--hero-order: 1;">
					I write about engineering, product thinking, and lessons learned while building things on the
					internet.
				</p>
				<div class="actions" data-reveal="hero" style="--hero-order: 2;">
					<a href="/blog">Read the blog</a>
					<a href="/contact">Get in touch</a>
				</div>
			</section>

			<section class="about-dossier" aria-label="About Me" data-reveal>
				<div class="dossier-grid">
					<div class="dossier-block" data-reveal style="--stagger: 0;">
						<h3>Current Status</h3>
						<p>Engineering systems, writing about the process, and building robust web architectures.</p>
					</div>
					<div class="dossier-block" data-reveal style="--stagger: 1;">
						<h3>Core Stack</h3>
						<ul class="mono-list">
							<li>TypeScript / Node.js</li>
							<li>React / Astro</li>
							<li>Docker / Azure CI/CD</li>
						</ul>
					</div>
					<div class="dossier-block" data-reveal style="--stagger: 2;">
						<h3>Philosophy</h3>
						<p>Build durable tools. Write clear documentation. Keep the web fast and weird.</p>
					</div>
				</div>
			</section>

			<section class="latest" data-reveal>
				<div class="section-head" data-reveal>
					<h2>Latest writing</h2>
					<a href="/blog">View all posts</a>
				</div>
				<ul>
					{
						latestPosts.map((post, index) => (
							<li class="latest-item" data-reveal style={`--stagger: ${index};`}>
								<p class="meta">
									<FormattedDate date={post.data.pubDate} />
								</p>
								<h3>
									<a href={`/blog/${post.id}/`}>{post.data.title}</a>
								</h3>
								<p>{post.data.description}</p>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<script is:inline>
			const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
			if (!prefersReducedMotion) {
				document.documentElement.classList.add('motion-ready');
				const revealElements = document.querySelectorAll('[data-reveal]:not([data-reveal="hero"])');
				if ('IntersectionObserver' in window) {
					const observer = new IntersectionObserver(
						(entries) => {
							entries.forEach((entry) => {
								if (entry.isIntersecting) {
									entry.target.classList.add('in-view');
									observer.unobserve(entry.target);
								}
							});
						},
						{ threshold: 0.2, rootMargin: '0px 0px -10% 0px' },
					);
					revealElements.forEach((element) => observer.observe(element));
				} else {
					revealElements.forEach((element) => element.classList.add('in-view'));
				}
			}
		</script>
		<Footer />
	</body>
</html>
<style>
	:root {
		--ease-out-quart: cubic-bezier(0.25, 1, 0.5, 1);
		--ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
	}

	.home {
		display: grid;
		gap: 3rem;
	}
	.hero h1 {
		font-size: clamp(3rem, 7vw, 4.5rem);
		margin-bottom: 0.75rem;
		letter-spacing: -0.02em;
		color: color-mix(in oklch, var(--accent-dark) 70%, rgb(var(--black)));
		line-height: 1.05;
	}
	.eyebrow {
		font-size: 0.85rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: rgb(var(--black));
		font-family: var(--font-mono);
		font-weight: 700;
		margin-bottom: 1rem;
		border-bottom: 1.5px solid rgb(var(--black));
		display: inline-block;
		padding-bottom: 0.2rem;
	}
	.hero p {
		max-width: 56ch;
		font-size: 1.1rem;
		line-height: 1.72;
	}
	.actions {
		display: flex;
		gap: 1rem;
		margin-top: 1.5rem;
		font-family: var(--font-mono);
		text-transform: uppercase;
		font-size: 0.78rem;
		font-weight: 600;
		letter-spacing: 0.055em;
	}
	.actions a {
		border: 1.5px solid color-mix(in oklch, var(--ink-blue) 34%, rgb(var(--black)));
		padding: 0.5rem 1rem;
		text-decoration: none;
		color: rgb(var(--black));
		background: color-mix(in oklch, var(--ink-blue-soft) 62%, var(--surface));
		transition:
			transform 220ms var(--ease-out-quart),
			background-color 220ms var(--ease-out-quart),
			color 220ms var(--ease-out-quart),
			box-shadow 220ms var(--ease-out-quart);
		will-change: transform;
	}
	.actions a:first-child {
		background: var(--accent);
		border-color: var(--accent-dark);
		color: oklch(0.22 0.03 258);
	}
	.actions a:hover {
		background: color-mix(in oklch, var(--accent) 82%, white);
		color: oklch(0.2 0.03 258);
		transform: translateY(-2px) scale(1.02);
		box-shadow: 3px 3px 0 color-mix(in oklch, var(--accent-dark) 65%, rgb(var(--black)));
	}
	.actions a:active {
		transform: translateY(0) scale(0.98);
		transition-duration: 120ms;
	}
	.section-head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 1.5rem;
		border-bottom: 2px solid color-mix(in oklch, var(--ink-blue) 45%, rgb(var(--black)));
		padding-bottom: 0.5rem;
	}
	.section-head h2 {
		margin: 0;
	}
	.section-head a {
		font-family: var(--font-mono);
		font-size: 0.76rem;
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--ink-blue);
	}
	.latest ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: 1.5rem;
	}
	.latest li {
		border: 1.5px solid color-mix(in oklch, var(--ink-blue) 30%, rgb(var(--black)));
		padding: 1.5rem;
		background: color-mix(in oklch, var(--ink-blue-soft) 66%, var(--surface));
		transition:
			transform 260ms var(--ease-out-quart),
			box-shadow 260ms var(--ease-out-quart);
		will-change: transform;
	}
	.latest li:nth-child(odd) {
		background: color-mix(in oklch, var(--accent-soft) 60%, var(--surface));
	}
	.latest li:hover {
		transform: translateY(-4px);
		box-shadow: 4px 4px 0 color-mix(in oklch, var(--ink-blue) 58%, rgb(var(--black)));
	}
	.latest h3 {
		margin: 0.5rem 0;
		font-size: clamp(1.45rem, 2.9vw, 2rem);
		line-height: 1.12;
	}
	.latest h3 a {
		text-decoration: none;
	}
	.latest h3 a:hover {
		background: transparent;
		color: var(--accent);
	}
	.meta {
		margin: 0;
		color: rgb(var(--black));
		font-family: var(--font-mono);
		font-size: 0.74rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		font-variant-numeric: tabular-nums;
		border-bottom: 1.5px solid color-mix(in oklch, var(--accent) 70%, rgb(var(--black)));
		display: inline-block;
		padding-bottom: 0.25rem;
		margin-bottom: 0.5rem;
	}

	.about-dossier { 
		margin: 4rem 0; 
	}
	.dossier-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 1.5px; /* Creates inner borders */
		background: color-mix(in oklch, var(--accent) 35%, var(--ink-blue)); /* Color of borders */
		border: 1.5px solid color-mix(in oklch, var(--ink-blue) 55%, rgb(var(--black))); /* Outer border */
	}
	.dossier-block {
		padding: 1.5rem;
		background: color-mix(in oklch, var(--ink-blue-soft) 55%, var(--surface)); /* Item background */
		transition:
			transform 260ms var(--ease-out-quart),
			box-shadow 260ms var(--ease-out-quart);
		will-change: transform;
	}
	.dossier-block:nth-child(2) {
		background: color-mix(in oklch, var(--accent-soft) 64%, var(--surface));
	}
	.dossier-block:nth-child(3) {
		background: color-mix(in oklch, var(--ink-blue-soft) 72%, var(--surface));
	}
	.dossier-block:hover {
		transform: translateY(-3px);
		box-shadow: 3px 3px 0 color-mix(in oklch, var(--accent-dark) 55%, rgb(var(--black)));
	}
	.dossier-block h3 {
		font-family: var(--font-mono);
		font-weight: 600;
		font-size: 0.76rem;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		border-bottom: 1.5px solid color-mix(in oklch, var(--ink-blue) 52%, rgb(var(--black)));
		padding-bottom: 0.5rem;
		margin-bottom: 1rem;
	}
	.mono-list { 
		list-style: square; 
		padding-left: 1.25rem; 
		margin: 0;
		line-height: 1.68;
	}
	.mono-list li::marker {
		color: var(--accent);
	}

	html.motion-ready .hero [data-reveal='hero'] {
		opacity: 0;
		animation: hero-reveal 700ms var(--ease-out-expo) forwards;
		animation-delay: calc(var(--hero-order, 0) * 120ms + 80ms);
	}
	html.motion-ready [data-reveal]:not([data-reveal='hero']) {
		opacity: 0;
		transform: translateY(14px);
	}
	html.motion-ready [data-reveal].in-view {
		animation: section-reveal 520ms var(--ease-out-quart) forwards;
		animation-delay: calc(var(--stagger, 0) * 90ms);
	}

	@keyframes hero-reveal {
		from {
			opacity: 0;
			transform: translateY(16px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@keyframes section-reveal {
		from {
			opacity: 0;
			transform: translateY(14px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.actions a,
		.latest li,
		.dossier-block {
			transition: none;
			transform: none;
			box-shadow: none;
			will-change: auto;
		}
		html.motion-ready .hero [data-reveal='hero'],
		html.motion-ready [data-reveal]:not([data-reveal='hero']),
		html.motion-ready [data-reveal].in-view {
			opacity: 1;
			transform: none;
			animation: none;
		}
	}
</style>
