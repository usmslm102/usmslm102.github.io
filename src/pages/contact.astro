---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import RouteMotion from '../components/RouteMotion.astro';
import { CONTACT_EMAIL, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Contact | ${SITE_TITLE}`} description="Get in touch with Usama Ansari." />
	</head>
	<body>
		<Header />
		<main class="page">
			<section class="contact-shell" data-route-reveal style="--stagger: 0;">
				<h1>Contact</h1>
				<p>
					You can connect on
					<a href="https://www.linkedin.com/in/usamaansari/" target="_blank" rel="noreferrer">LinkedIn</a>
					,
					<a href="https://github.com/usmslm102" target="_blank" rel="noreferrer">GitHub</a>
					, and
					<a href="https://x.com/usmslm102" target="_blank" rel="noreferrer">X</a>.
				</p>
				<div class="contact-actions">
					<button class="copy-email-btn" type="button" data-copy-email data-email={CONTACT_EMAIL}>
						Copy email
					</button>
					<span class="copy-feedback" data-copy-feedback aria-live="polite" role="status"></span>
				</div>
			</section>
		</main>
		<script is:inline>
			const copyButton = document.querySelector('[data-copy-email]');
			const copyFeedback = document.querySelector('[data-copy-feedback]');
			const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
			const feedbackMessages = ['Copied. Thanks for reaching out.', 'Copied. Looking forward to connecting.'];
			const setFeedback = (message, success) => {
				if (!copyFeedback) return;
				copyFeedback.textContent = message;
				copyFeedback.dataset.state = success ? 'success' : 'error';
				window.setTimeout(() => {
					copyFeedback.textContent = '';
					delete copyFeedback.dataset.state;
				}, 2200);
			};

			copyButton?.addEventListener('click', async () => {
				const email = copyButton.getAttribute('data-email');
				if (!email || !copyFeedback) return;

				if (!navigator.clipboard || !window.isSecureContext) {
					setFeedback(`Copy is unavailable here. Email me at ${email}.`, false);
					return;
				}

				try {
					await navigator.clipboard.writeText(email);
					copyButton.classList.add('copied');
					setFeedback(feedbackMessages[Math.floor(Math.random() * feedbackMessages.length)], true);
					if (!prefersReducedMotion) {
						window.setTimeout(() => copyButton.classList.remove('copied'), 260);
					} else {
						copyButton.classList.remove('copied');
					}
				} catch {
					setFeedback(`Could not copy right now. Email me at ${email}.`, false);
				}
			});
		</script>
		<RouteMotion />
		<Footer />
	</body>
</html>

<style>
	.contact-shell {
		border: 1.5px solid color-mix(in oklch, var(--ink-blue) 42%, rgb(var(--black)));
		padding: 1.5rem;
		background: color-mix(in oklch, var(--accent-soft) 52%, var(--surface));
		max-width: 68ch;
		transition:
			transform 260ms var(--ease-out-quart),
			box-shadow 260ms var(--ease-out-quart);
		will-change: transform;
	}
	.contact-shell p {
		max-width: 62ch;
		font-size: 1.04rem;
		line-height: 1.72;
	}
	.contact-shell:hover {
		transform: translateY(-3px);
		box-shadow: 4px 4px 0 color-mix(in oklch, var(--accent-dark) 55%, rgb(var(--black)));
	}
	.contact-shell a {
		transition:
			color 220ms var(--ease-out-quart),
			background-color 220ms var(--ease-out-quart);
	}
	.contact-actions {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-top: 1rem;
	}
	.copy-email-btn {
		border: 1.5px solid var(--accent-dark);
		background: var(--accent);
		color: oklch(0.22 0.03 258);
		font: inherit;
		text-transform: uppercase;
		font-size: 0.76rem;
		font-weight: 600;
		letter-spacing: 0.06em;
		padding: 0.45rem 0.7rem;
		min-height: 2.75rem;
		cursor: pointer;
		transition:
			transform 180ms var(--ease-out-quart),
			background-color 180ms var(--ease-out-quart),
			color 180ms var(--ease-out-quart),
			box-shadow 180ms var(--ease-out-quart);
	}
	.copy-email-btn:hover {
		background: color-mix(in oklch, var(--accent) 84%, white);
		color: oklch(0.2 0.03 258);
		transform: translateY(-2px);
		box-shadow: 3px 3px 0 color-mix(in oklch, var(--accent-dark) 62%, rgb(var(--black)));
	}
	.copy-email-btn:active,
	.copy-email-btn.copied {
		transform: translateY(1px) scale(0.98);
		box-shadow: none;
	}
	.copy-email-btn:focus-visible {
		outline: 2px solid var(--ink-blue);
		outline-offset: 2px;
	}
	.copy-feedback {
		font-size: 0.72rem;
		font-family: var(--font-mono);
		text-transform: uppercase;
		letter-spacing: 0.06em;
		min-height: 1.2em;
	}
	.copy-feedback[data-state='success'] {
		color: var(--success);
	}
	.copy-feedback[data-state='error'] {
		color: var(--danger);
	}

	@media (prefers-reduced-motion: reduce) {
		.contact-shell,
		.contact-shell a,
		.copy-email-btn {
			transition: none;
			will-change: auto;
		}
		.contact-shell:hover {
			transform: none;
			box-shadow: none;
		}
		.copy-email-btn:hover,
		.copy-email-btn:active,
		.copy-email-btn.copied {
			transform: none;
			box-shadow: none;
		}
	}
</style>
