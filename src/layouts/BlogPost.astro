---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & { id?: string };

const { title, description, pubDate, updatedDate, heroImage, id } = Astro.props;

// Construct the URL logically
const githubRepoPath = "https://github.com/usmslm102/usmslm102.github.io/blob/master/src/content/blog";
const editUrl = id ? `${githubRepoPath}/${id}.md` : null;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: 100%;
				max-width: 100%;
				padding-top: 2rem;
			}
			.article-shell {
				width: 780px;
				max-width: calc(100% - 2rem);
				margin: 0 auto;
			}
			.back {
				display: inline-block;
				margin-bottom: 1.5rem;
				font-size: 0.85rem;
				text-decoration: none;
				font-family: var(--font-mono);
				font-weight: 700;
				text-transform: uppercase;
				border: 1.5px solid rgb(var(--black));
				padding: 0.35rem 0.75rem;
				transition: all 0.2s ease;
			}
			.back:hover {
				background: rgb(var(--black));
				color: var(--surface);
			}
			.hero-image {
				width: 100%;
				margin-bottom: 2rem;
			}
			.hero-image img {
				border-radius: 0;
				border: 1px solid rgb(var(--black));
			}
			.prose {
				width: 100%;
				max-width: 66ch;
				margin: 0 auto;
				padding: 0 0 3rem;
				color: rgb(var(--black));
			}
			.title {
				margin-bottom: 1.5rem;
				padding-bottom: 1rem;
				border-bottom: 2px solid rgb(var(--black));
			}
			.title h1 {
				margin: 0 0 0.5rem;
				line-height: 1.15;
			}
			.description {
				margin: 0;
				color: rgb(var(--black));
			}
			.meta-bar {
				display: flex;
				justify-content: space-between;
				align-items: flex-start;
				border-bottom: 1.5px solid rgb(var(--black));
				padding-bottom: 0.75rem;
				margin-bottom: 1.5rem;
				font-family: var(--font-mono);
				font-size: 0.85rem;
				text-transform: uppercase;
			}
			.date {
				color: rgb(var(--black));
			}
			.date p {
				margin: 0;
			}
			.github-edit-btn {
				color: rgb(var(--black));
				text-decoration: none;
				background: var(--surface);
				font-weight: 700;
				transition: all 0.2s ease;
				padding: 0.15rem 0;
			}
			.github-edit-btn:hover {
				color: var(--surface);
				background: var(--accent);
			}
			.last-updated-on {
				font-style: italic;
				margin-top: 0.2rem;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<div class="article-shell">
				<a class="back" href="/blog">&larr; All posts</a>
				<article>
					<div class="title">
						<div class="meta-bar">
							<div class="date">
								<p><FormattedDate date={pubDate} /></p>
								{
									updatedDate && (
										<p class="last-updated-on">
											Updated <FormattedDate date={updatedDate} />
										</p>
									)
								}
							</div>
							{editUrl && (
								<a href={editUrl} class="github-edit-btn" target="_blank" rel="noopener noreferrer">
									[ Edit File on GitHub ] &#8599;
								</a>
							)}
						</div>
						<h1>{title}</h1>
						<p class="description">{description}</p>
					</div>
					{heroImage && (
						<div class="hero-image">
							<Image width={1020} height={510} src={heroImage} alt="" />
						</div>
					)}
					<div class="prose">
						<slot />
					</div>
				</article>
			</div>
		</main>
		<Footer />
	</body>
</html>
